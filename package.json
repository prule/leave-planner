{
  "name": "leave-planner",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:cf",
    "build:cf": "vue-tsc -b && vite build --base=/",
    "build:gh": "vue-tsc -b && vite build --base=/leave-planner/",
    "preview": "vite preview",
    "deploy": "npm run deploy:cf && npm run deploy:gh",
    "deploy:cf": "npm run build:cf && wrangler pages deploy dist",
    "deploy:gh": "npm run build:gh && gh-pages -d dist"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "chartjs-plugin-datalabels": "2.2.0",
    "pinia": "3.0.4",
    "vue": "3.5.29",
    "vue-chartjs": "5.3.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@vitejs/plugin-vue": "6.0.4",
    "autoprefixer": "10.4.27",
    "gh-pages": "6.3.0",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-pwa": "1.2.0",
    "vue-tsc": "3.2.5",
    "workbox-window": "7.4.1",
    "wrangler": "4.112.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
